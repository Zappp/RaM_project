{
  "imports": {
    "@supabase/functions-js": "jsr:@supabase/functions-js@^2.90.0",
    "@supabase/supabase-js": "jsr:@supabase/supabase-js@^2.89.0",
    "@supabase/ssr": "npm:@supabase/ssr@^0.8.0",
    "hono": "https://deno.land/x/hono@v3.11.7/mod.ts",
    "hono/cors": "https://deno.land/x/hono@v3.11.7/middleware/cors/index.ts",
    "@supabase/realtime-js": "npm:@supabase/realtime-js@^2.89.0",
    "@supabase/postgrest-js": "npm:@supabase/postgrest-js@^2.89.0",
    "@supabase/storage-js": "npm:@supabase/storage-js@^2.89.0",
    "@supabase/auth-js": "npm:@supabase/auth-js@^2.89.0",
    "graphql": "npm:graphql@^16.8.1",
    "graphql-yoga": "npm:graphql-yoga@^5.18.0",
    "@graphql-tools/schema": "npm:@graphql-tools/schema@^10.0.30",
    "@graphql-tools/utils": "npm:@graphql-tools/utils@^10.11.0",
    "@std/assert": "jsr:@std/assert@0.208.0",
    "@std/encoding/base64url": "jsr:@std/encoding@0.208.0/base64url",
    "zod": "npm:zod@^4.0.0",
    "jose": "npm:jose@^5.0.0",
    "@/": "./src/"
  },
  "tasks": {
    "cache": "deno cache --node-modules-dir --lock deno.lock --reload src/runtime.ts",
    "check": "deno check --node-modules-dir --lock deno.lock src/runtime.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "SUPABASE_URL=https://test.supabase.co SUPABASE_ANON_KEY=test-key SUPABASE_SERVICE_ROLE_KEY=test-service-key API_URL=http://localhost:54321/functions/v1/graphql FRONTEND_URL=http://localhost:3000 deno test --allow-env --allow-net --node-modules-dir --lock deno.lock src/features/**/*.test.ts",
    "dev": "npx supabase functions serve graphql --env-file ../.env",
    "run": "deno run --watch --allow-env --allow-read --allow-net --env-file=../.env --node-modules-dir --lock deno.lock src/runtime.ts"
  }
}
